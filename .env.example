# ─── Your Own World — environment variables ─────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored. Never commit real credentials.
#
# VITE_ prefix  → exposed to the browser bundle (public, safe for keys
#                  that are designed to be public, like anon keys)
# No prefix     → server-side only, used by Vercel API routes (api/*.js)
#                  Set these in the Vercel dashboard under Settings → Environment Variables


# ── Supabase ─────────────────────────────────────────────────────────────────
# Project dashboard → Settings → API

# Public anon key — safe to expose, access is controlled by Row Level Security
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Also needed server-side (Vercel API routes verify auth tokens against Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to browser. Used by stripe-webhook and
# create-customer-portal to write subscription data back to user app_metadata.
# Project dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── Stripe ───────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys  /  Products → Prices

# Secret key — server-side only, never put in VITE_ vars
STRIPE_SECRET_KEY=sk_test_...

# The recurring price ID for the membership product
STRIPE_PRICE_ID=price_...

# Webhook signing secret — Stripe dashboard → Webhooks → your endpoint → Signing secret
# For local testing with the Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...


# ── App URL ──────────────────────────────────────────────────────────────────
# Used by Stripe for success/cancel redirect URLs.
# In production this is your Vercel deployment URL.
# Locally: http://localhost:3000 when using `vercel dev`, or http://localhost:5173 for `npm run dev`
SITE_URL=http://localhost:3000


# ── API endpoint URLs (browser-accessible) ───────────────────────────────────
# In production these are relative paths — Vercel routes /api/* automatically.
# Change to full URLs only if running the API on a different domain.
VITE_CREATE_CHECKOUT_SESSION_URL=/api/create-checkout-session
VITE_CUSTOMER_PORTAL_URL=/api/create-customer-portal


# ── AI providers ─────────────────────────────────────────────────────────────
# At least one of these is required for the AI assistant to work.

# OpenRouter (recommended default — free tier available, access to many models)
# openrouter.ai → Keys
VITE_OPENROUTER_API_KEY=sk-or-...

# Google AI Studio (optional — for Gemini / Gemma models directly)
# aistudio.google.com → Get API key
# VITE_GOOGLE_AI_API_KEY=AIza...

# Anthropic (optional — for Claude models directly)
# console.anthropic.com → API Keys
# VITE_ANTHROPIC_API_KEY=sk-ant-...


# ── Dev helpers ───────────────────────────────────────────────────────────────
# Auto-fills the login form in development mode only.
# Remove or leave blank in production.
VITE_DEV_EMAIL=you@example.com
VITE_DEV_PASSWORD=your-password
