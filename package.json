{
  "name": "yow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "check:load": "node ./scripts/check-load.mjs",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "qa": "npm run lint && npm run test && npm run build && npm run check:load",
    "qa:all": "npm run qa && npm run qa:smoke",
    "qa:smoke:install": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-/private/tmp/yow-ms-playwright} playwright install chromium",
    "qa:smoke": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-/private/tmp/yow-ms-playwright} playwright test --config playwright.config.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@vercel/analytics": "^2.0.1",
    "docx": "^9.6.1",
    "fflate": "^0.8.3",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^22.1.1"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "rollup": "^4.60.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.9"
  }
}
