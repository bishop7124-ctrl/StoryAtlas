{
  "name": "yow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:desktop": "vite --host 127.0.0.1 --mode desktop",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "build:desktop": "vite build --mode desktop",
    "check:load": "node ./scripts/check-load.mjs",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "qa": "npm run lint && npm run test && npm run build && npm run check:load",
    "qa:all": "npm run qa && npm run qa:smoke",
    "qa:smoke:install": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-/private/tmp/yow-ms-playwright} playwright install chromium",
    "qa:smoke": "PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-/private/tmp/yow-ms-playwright} playwright test --config playwright.config.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:app": "tauri build --bundles app",
    "desktop:build:nsis": "tauri build --bundles nsis",
    "desktop:package:dmg:local": "bash scripts/package-macos-dmg-local.sh",
    "desktop:package:zip:local": "bash scripts/package-macos-zip-local.sh",
    "desktop:build:local": "npm run desktop:build:app && npm run desktop:package:dmg:local"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vercel/analytics": "^2.0.1",
    "docx": "^9.6.1",
    "fflate": "^0.8.3",
    "nodemailer": "^9.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^22.1.1"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "caniuse-lite": "1.0.30001797"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "rollup": "^4.60.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.9"
  }
}
